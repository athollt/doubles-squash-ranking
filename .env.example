# Database
DATABASE_URL=postgresql://postgres:password@localhost:5433/squash

# Auth.js v5
# AUTH_SECRET is read by Auth.js v5 (NEXTAUTH_SECRET is accepted as a fallback).
# AUTH_URL must equal the public origin in production.
AUTH_URL=http://localhost:3001
AUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub (for PR creation via API)
GITHUB_TOKEN=your-github-personal-access-token
