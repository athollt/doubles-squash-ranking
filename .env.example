# This file documents LOCAL development variables (copy to a gitignored .env).
# In PRODUCTION on Fly.io these are NOT read from a file: the runtime values are
# Fly secrets (see docs/DEPLOYMENT.md). DATABASE_URL is set automatically by
# `fly postgres attach`; AUTH_URL/AUTH_SECRET/GOOGLE_* are set via `fly secrets`.

# Database
# Local: the docker-compose Postgres on port 5433. Production: set by Fly on attach.
DATABASE_URL=postgresql://postgres:password@localhost:5433/squash

# Auth.js v5
# AUTH_SECRET is read by Auth.js v5 (NEXTAUTH_SECRET is accepted as a fallback).
# AUTH_URL must equal the public origin (prod: https://app.rungs.co.za).
AUTH_URL=http://localhost:3001
AUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# Google OAuth (same client serves local + prod redirect URIs; see step 14.1)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Seed admin password (LOCAL/DEV ONLY) — sets the Credentials-login password for
# the seeded admin (atholl@tomlinson.co.za) when running `prisma db seed`.
# Defaults to "localdev" if unset. Production signs in with Google, not this.
SEED_ADMIN_PASSWORD=localdev

# GitHub (for PR creation via API)
GITHUB_TOKEN=your-github-personal-access-token

# Fly.io — LOCAL CLI only (running `fly ...` from your machine).
# CI deploys with a separate deploy-scoped token stored as the GitHub Actions
# secret FLY_API_TOKEN (set in the repo, not here). See docs/DEPLOYMENT.md.
FLY_API_TOKEN=your-fly-api-token
